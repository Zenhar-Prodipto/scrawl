# Database Configuration
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=your_database_name
DB_HOST=db
DB_PORT=5432
DB_EXTERNAL_PORT=5434
DB_DEV_PORT=5435
DB_PROD_PORT=5436

# Redis Configuration
REDIS_URL=redis://redis:6379/1
REDIS_EXTERNAL_PORT=6379
REDIS_DEV_PORT=6380
REDIS_PROD_PORT=6381

# Kafka Configuration
KAFKA_BROKER=kafka_broker:9092
KAFKA_EXTERNAL_PORT=9092
KAFKA_DEV_PORT=9093
KAFKA_PROD_PORT=9094
ZOOKEEPER_EXTERNAL_PORT=2181
ZOOKEEPER_DEV_PORT=2182
ZOOKEEPER_PROD_PORT=2183

# Application Ports
DJANGO_PORT=8000
DJANGO_DEV_PORT=8001
DJANGO_PROD_PORT=8002

# Monitoring Stack Ports
GRAFANA_PORT=3000
GRAFANA_DEV_PORT=3001
GRAFANA_PROD_PORT=3002
PROMETHEUS_PORT=9090
PROMETHEUS_DEV_PORT=9091
PROMETHEUS_PROD_PORT=9092
KIBANA_PORT=5601
KIBANA_DEV_PORT=5602
KIBANA_PROD_PORT=5603
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_DEV_PORT=9201
ELASTICSEARCH_PROD_PORT=9202
LOGSTASH_PORT=5000
LOGSTASH_DEV_PORT=5001
LOGSTASH_PROD_PORT=5002

# Application Configuration
DEBUG=False
ENVIRONMENT=local

# Production Secrets (change in production)
GRAFANA_PASSWORD=your_grafana_password

# Allowed hosts for Django
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web,0.0.0.0
