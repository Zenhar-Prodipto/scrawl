{
  "dashboard": {
    "id": null,
    "title": "Scrawl Social Media Platform - Complete Monitoring",
    "tags": ["scrawl", "social-media", "monitoring", "business-metrics"],
    "style": "dark",
    "timezone": "browser",
    "editable": true,
    "hideControls": false,
    "graphTooltip": 1,
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": [
        "5s",
        "10s",
        "30s",
        "1m",
        "5m",
        "15m",
        "30m",
        "1h",
        "2h",
        "1d"
      ],
      "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
    },
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "🏥 System Health Overview",
        "type": "stat",
        "targets": [
          {
            "expr": "scrawl_system_health",
            "legendFormat": "{{component}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 0.5 },
                { "color": "green", "value": 1 }
              ]
            },
            "mappings": [
              { "options": { "0": { "text": "🔴 DOWN" } }, "type": "value" },
              { "options": { "1": { "text": "🟢 UP" } }, "type": "value" }
            ]
          }
        },
        "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"],
            "fields": ""
          },
          "orientation": "horizontal",
          "textMode": "auto",
          "colorMode": "background"
        }
      },
      {
        "id": 2,
        "title": "📊 Business Metrics - User Activity",
        "type": "stat",
        "targets": [
          {
            "expr": "increase(scrawl_posts_created_total[1h])",
            "legendFormat": "Posts Created",
            "refId": "A"
          },
          {
            "expr": "increase(scrawl_authentication_events_total{result=\"success\"}[1h])",
            "legendFormat": "Successful Logins",
            "refId": "B"
          },
          {
            "expr": "increase(scrawl_user_registrations_total[1h])",
            "legendFormat": "New Users",
            "refId": "C"
          },
          {
            "expr": "increase(scrawl_follows_created_total[1h])",
            "legendFormat": "New Follows",
            "refId": "D"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "unit": "short"
          }
        },
        "gridPos": { "h": 6, "w": 24, "x": 0, "y": 4 },
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"],
            "fields": ""
          },
          "orientation": "horizontal",
          "textMode": "auto",
          "colorMode": "value"
        }
      },
      {
        "id": 3,
        "title": "🚀 API Performance - Response Times",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(scrawl_api_request_duration_seconds_bucket[5m]))",
            "legendFormat": "95th percentile",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, rate(scrawl_api_request_duration_seconds_bucket[5m]))",
            "legendFormat": "50th percentile (median)",
            "refId": "B"
          },
          {
            "expr": "rate(scrawl_api_request_duration_seconds_sum[5m]) / rate(scrawl_api_request_duration_seconds_count[5m])",
            "legendFormat": "Average response time",
            "refId": "C"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": {
              "axisLabel": "Response Time",
              "axisPlacement": "auto",
              "drawStyle": "line",
              "fillOpacity": 10,
              "lineWidth": 2,
              "pointSize": 5,
              "showPoints": "never",
              "spanNulls": false
            },
            "unit": "s",
            "min": 0
          }
        }
      },
      {
        "id": 4,
        "title": "📈 API Request Rate by Endpoint",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(scrawl_api_requests_total[5m])",
            "legendFormat": "{{endpoint}} ({{method}}) - {{status_code}}",
            "refId": "A"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": {
              "axisLabel": "Requests/sec",
              "axisPlacement": "auto",
              "drawStyle": "line",
              "fillOpacity": 10,
              "lineWidth": 2,
              "pointSize": 5,
              "showPoints": "never",
              "spanNulls": false
            },
            "unit": "reqps",
            "min": 0
          }
        }
      },
      {
        "id": 5,
        "title": "💬 Post Interactions",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(scrawl_post_interactions_total{action=\"create\"}[5m])",
            "legendFormat": "{{interaction_type}} Created",
            "refId": "A"
          },
          {
            "expr": "rate(scrawl_post_interactions_total{action=\"delete\"}[5m])",
            "legendFormat": "{{interaction_type}} Deleted",
            "refId": "B"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": {
              "axisLabel": "Interactions/sec",
              "axisPlacement": "auto",
              "drawStyle": "line",
              "fillOpacity": 10,
              "lineWidth": 2,
              "pointSize": 5,
              "showPoints": "never",
              "spanNulls": false
            },
            "unit": "short",
            "min": 0
          }
        }
      },
      {
        "id": 6,
        "title": "👥 Follow Activity",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(scrawl_follow_interactions_total[5m])",
            "legendFormat": "{{interaction_type}} - {{action}}",
            "refId": "A"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": {
              "axisLabel": "Follow Actions/sec",
              "axisPlacement": "auto",
              "drawStyle": "line",
              "fillOpacity": 10,
              "lineWidth": 2,
              "pointSize": 5,
              "showPoints": "never",
              "spanNulls": false
            },
            "unit": "short",
            "min": 0
          }
        }
      },
      {
        "id": 7,
        "title": "🍽️ Feed Performance",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(scrawl_feed_generation_duration_seconds_sum[5m]) / rate(scrawl_feed_generation_duration_seconds_count[5m])",
            "legendFormat": "Average Feed Generation Time",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(scrawl_feed_generation_duration_seconds_bucket[5m]))",
            "legendFormat": "95th percentile Feed Generation",
            "refId": "B"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": {
              "axisLabel": "Generation Time",
              "axisPlacement": "auto",
              "drawStyle": "line",
              "fillOpacity": 10,
              "lineWidth": 2,
              "pointSize": 5,
              "showPoints": "never",
              "spanNulls": false
            },
            "unit": "s",
            "min": 0
          }
        }
      },
      {
        "id": 8,
        "title": "💾 Feed Cache Performance",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(scrawl_feed_requests_total{cache_result=\"hit\"}[5m]) / rate(scrawl_feed_requests_total[5m]) * 100",
            "legendFormat": "Cache Hit Rate",
            "refId": "A"
          },
          {
            "expr": "rate(scrawl_feed_requests_total{cache_result=\"miss\"}[5m])",
            "legendFormat": "Cache Misses/sec",
            "refId": "B"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 50 },
                { "color": "green", "value": 80 }
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"],
            "fields": ""
          },
          "orientation": "horizontal",
          "textMode": "auto",
          "colorMode": "background"
        }
      },
      {
        "id": 9,
        "title": "🔒 Authentication Events",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(scrawl_authentication_events_total{result=\"success\"}[5m])",
            "legendFormat": "{{event_type}} Success",
            "refId": "A"
          },
          {
            "expr": "rate(scrawl_authentication_events_total{result=\"failure\"}[5m])",
            "legendFormat": "{{event_type}} Failure",
            "refId": "B"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 34 },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": {
              "axisLabel": "Events/sec",
              "axisPlacement": "auto",
              "drawStyle": "line",
              "fillOpacity": 10,
              "lineWidth": 2,
              "pointSize": 5,
              "showPoints": "never",
              "spanNulls": false
            },
            "unit": "short",
            "min": 0
          }
        }
      },
      {
        "id": 10,
        "title": "🚨 Error Rate by Status Code",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(scrawl_api_requests_total{status_code=~\"4..\"}[5m])",
            "legendFormat": "4xx Errors - {{endpoint}}",
            "refId": "A"
          },
          {
            "expr": "rate(scrawl_api_requests_total{status_code=~\"5..\"}[5m])",
            "legendFormat": "5xx Errors - {{endpoint}}",
            "refId": "B"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 34 },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": {
              "axisLabel": "Errors/sec",
              "axisPlacement": "auto",
              "drawStyle": "line",
              "fillOpacity": 10,
              "lineWidth": 2,
              "pointSize": 5,
              "showPoints": "never",
              "spanNulls": false
            },
            "unit": "short",
            "min": 0
          }
        }
      },
      {
        "id": 11,
        "title": "📡 Kafka Message Flow",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(scrawl_kafka_messages_published_total[5m])",
            "legendFormat": "Published: {{topic}} - {{status}}",
            "refId": "A"
          },
          {
            "expr": "rate(scrawl_kafka_messages_consumed_total[5m])",
            "legendFormat": "Consumed: {{topic}} - {{status}}",
            "refId": "B"
          }
        ],
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 42 },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": {
              "axisLabel": "Messages/sec",
              "axisPlacement": "auto",
              "drawStyle": "line",
              "fillOpacity": 10,
              "lineWidth": 2,
              "pointSize": 5,
              "showPoints": "never",
              "spanNulls": false
            },
            "unit": "short",
            "min": 0
          }
        }
      }
    ]
  },
  "overwrite": true
}
